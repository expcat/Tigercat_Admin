{
  "name": "tigercat-admin-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:vue": "pnpm --filter tigercat-admin-vue dev",
    "dev:react": "pnpm --filter tigercat-admin-react dev",
    "dev:demo:vue": "pnpm --filter tigercat-admin-vue dev:demo",
    "dev:demo:react": "pnpm --filter tigercat-admin-react dev:demo",
    "dev:demo:all": "pnpm --filter tigercat-admin-vue --filter tigercat-admin-react --parallel dev:demo",
    "build": "node scripts/build-frontends.mjs --data=api",
    "build:frontend": "node scripts/build-frontends.mjs",
    "build:demo": "node scripts/build-frontends.mjs --data=mock",
    "build:pages": "node scripts/build-frontends.mjs --deploy=pages",
    "build:vue": "node scripts/build-frontends.mjs --target=vue --data=api",
    "build:react": "node scripts/build-frontends.mjs --target=react --data=api",
    "build:all": "pnpm -r build",
    "e2e": "playwright test",
    "e2e:react": "playwright test --project=react",
    "e2e:vue": "playwright test --project=vue",
    "e2e:demo": "pnpm build:demo && playwright test --config=playwright.demo.config.ts",
    "e2e:install": "playwright install chromium",
    "db:script:postgres": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/generate-postgres-sql.ps1",
    "check:links": "pnpm dlx markdown-link-check README.md AGENT.md docs/llm.md docs/api.md docs/frontend.md docs/operations.md docs/api/auth.md docs/api/users.md docs/api/roles.md docs/api/dashboard-export.md docs/api/audit.md docs/api/notifications.md docs/api/tasks.md docs/api/settings.md docs/api/media.md Tigercat.Admin.Api/README.md"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
